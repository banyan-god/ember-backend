STORE_TO_SQL=1
SQLSERVER_HOST=192.168.1.164
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=Ember
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=replace-with-your-password
SQLSERVER_TRUST_SERVER_CERT=true

JWT_SECRET=replace-me-with-a-random-32-byte-minimum-secret
JWT_ISSUER=ember-backend
JWT_TTL_MINUTES=45
REFRESH_TOKEN_TTL_DAYS=3650

WEBAUTHN_RP_ID=example.com
WEBAUTHN_ALLOWED_ORIGINS=https://example.com
WEBAUTHN_MODE=strict
AASA_APP_IDS=ABCDE12345.com.example.emberpulse

CHALLENGE_TTL_SECONDS=300
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
SUGGESTED_SYNC_AFTER_SECONDS=21600
